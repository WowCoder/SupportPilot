# Flask application configuration
# Copy this file to .env and fill in your actual values

# Flask secret key - generate a random string for production
# You can use: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-here

# Alibaba Qwen API Key - required
QWEN_API_KEY=your-qwen-api-key-here

# Database URL (optional, defaults to SQLite)
# For production, use PostgreSQL or MySQL
# DATABASE_URL=postgresql://user:password@localhost:5432/supportpilot
DATABASE_URL=sqlite:///app.db

# Flask environment
# FLASK_ENV=production  # Options: development, production, testing
FLASK_DEBUG=false

# Upload folder (optional)
# UPLOAD_FOLDER=/var/www/supportpilot/uploads

# Gunicorn configuration (for production)
# GUNICORN_BIND=0.0.0.0:8000
# GUNICORN_WORKERS=4
# GUNICORN_LOG_LEVEL=info
